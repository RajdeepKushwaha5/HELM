# Required: Gemini AI
GEMINI_API_KEY_1=your_primary_gemini_api_key
GEMINI_API_KEY_2=your_second_gemini_api_key_optional
GEMINI_API_KEY_3=your_third_gemini_api_key_optional
GEMINI_MODEL=gemini-2.5-flash

# Required: GitHub repo to analyze
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repo-name

# Optional: Slack channel ID for incident message correlation (enables 4-source root cause)
SLACK_INCIDENTS_CHANNEL=your_incident_channel_id

# Optional: CircleCI project slug (enables CI Health 3-source panel)
# Format: gh/<org>/<repo>   e.g.  gh/myorg/myrepo
CIRCLECI_PROJECT_SLUG=gh/your-org/your-repo

# Optional: set if coral is not on PATH (Windows WSL — recommended).
# Use the same Coral config directory where all Helm sources are installed.
# CORAL_BIN=wsl -d Ubuntu -e /home/<your-username>/.cargo/bin/coral
# Or native Windows path:
# CORAL_BIN=C:\path\to\coral.exe

# Coral manages all source credentials — never in this file.
# Run once after installing Coral:
#   coral source add github    (prompts for GITHUB_TOKEN)
#   coral source add sentry    (prompts for SENTRY_ORG + SENTRY_TOKEN)
#   coral source add pagerduty (prompts for PAGERDUTY_API_TOKEN)
#   coral source add linear    (prompts for LINEAR_API_KEY)
#   coral source add slack     (prompts for SLACK_TOKEN)
